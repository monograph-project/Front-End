# Front-End ↔ Back-End (Vite exposes only vars prefixed with VITE_.)
#
# Dev (no CORS): leave API base EMPTY so the browser calls :5173; Vite proxies /api,/file,/students → gateway.
# Production / direct gateway: set e.g. VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=
VITE_DEV_PROXY_TARGET=http://localhost:8080
#
# Send cookies with API calls (required for HttpOnly session/refresh cookies and cross-origin auth).
# Omit or set false only if your gateway uses bearer tokens only with no cookie session.
VITE_API_WITH_CREDENTIALS=true
#
# If refresh uses an HttpOnly cookie (empty POST body to refresh), set true. Otherwise tokens come from SPA memory.
VITE_AUTH_COOKIE_REFRESH=false
#
# Optional: VITE_DEV_PROXY_STUDENTS_TO_LEGACY=true → /students & /departments → json-server (VITE_LEGACY_DEV_PROXY_TARGET).
VITE_DOCS_API_KEY=NxYtGyMROh0gHDMgDk1jX09GaFxJW3xLYVF2R2VJdlRwdF9FYUwxOX1dQl9lSXtTdUdiWX9dc31STmRXUkc=
